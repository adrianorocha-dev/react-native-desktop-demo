{
  "name": "MyApp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "macos": "react-native run-macos",
    "build:macos": "react-native build-macos --mode Release && APP_PATH=$(xcodebuild -workspace macos/MyApp.xcworkspace -scheme MyApp-macOS -sdk macosx -configuration Release -showBuildSettings -json 2>/dev/null | python3 -c \"import sys,json; settings=[s['buildSettings'] for s in json.load(sys.stdin) if s['buildSettings'].get('WRAPPER_EXTENSION')=='app'][0]; print(settings['TARGET_BUILD_DIR']+'/'+settings['FULL_PRODUCT_NAME'])\") && mkdir -p build && rm -rf build/MyApp.app && cp -R \"$APP_PATH\" build/",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/metro-config": "~54.0.2",
    "@react-native/new-app-screen": "^0.81.6",
    "@tailwindcss/postcss": "^4.3.0",
    "expo": "~54.0.10",
    "lightningcss": "^1.30.1",
    "nativewind": "^5.0.0-preview.4",
    "react": "^19.1.4",
    "react-native": "^0.81.6",
    "react-native-css": "^3.0.7",
    "react-native-macos": "^0.81.7",
    "react-native-reanimated": "~3.17.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-worklets": "^0.5.2",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "^0.81.6",
    "@react-native/eslint-config": "^0.81.6",
    "@react-native/metro-config": "^0.81.6",
    "@react-native/typescript-config": "^0.81.6",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "patch-package": "^8.0.1",
    "prettier": "2.8.8",
    "react-test-renderer": "^19.1.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
